# AI-TP OS - 环境变量配置模板
# 复制此文件为 .env 并填入你的实际值

# ============================================
# AI-TP OS 核心配置
# ============================================
AI_TP_MODE=standalone              # standalone | distributed | p2p
AI_TP_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
AI_TP_DATA_DIR=/data
AI_TP_MODELS_DIR=/models
AI_TP_STORAGE_DIR=/storage

# ============================================
# 推理后端配置 (本地优先)
# ============================================

# Ollama (默认本地推理)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# 可选：云 API 备用
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

GOOGLE_API_KEY=your-gemini-key-here
GOOGLE_MODEL=gemini-1.5-flash

XAI_API_KEY=your-xai-key-here

# LiteLLM 代理配置 (统一多 provider 接口)
LITELLM_PROXY_URL=
LITELLM_API_KEY=

# ============================================
# 存储层配置 (libai-storage)
# ============================================
AI_TP_STORAGE_BACKEND=sqlite       # sqlite | redis | memory | hybrid
AI_TP_STORAGE_SHARED=true          # 跨 Agent 共享记忆

# SQLite
SQLITE_DB_PATH=/data/ai-tp.db

# Redis (可选)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ============================================
# 网络层配置 (ai-tp-discovery)
# ============================================
AI_TP_NETWORK_ENABLED=true
AI_TP_NETWORK_MODE=hybrid          # local | mdns | dht | hybrid
AI_TP_DISCOVERY_PORT=8472
AI_TP_GATEWAY_PORT=8080

# P2P 配置
AI_TP_P2P_ENABLED=false
AI_TP_P2P_BOOTSTRAP_NODES=
AI_TP_P2P_IDENTITY_KEY=

# NAT 穿透
AI_TP_NAT_ENABLED=true
AI_TP_NAT_STUN_SERVERS=stun.l.google.com:19302

# ============================================
# 计算层配置 (ai-tp-scheduler)
# ============================================
AI_TP_SCHEDULER_ENABLED=false
AI_TP_SCHEDULER_BACKEND=local      # local | distributed
AI_TP_SCHEDULER_MAX_WORKERS=4
AI_TP_SCHEDULER_GPU_ENABLED=false

# ============================================
# 应用层配置
# ============================================

# Streamlit
STREAMLIT_SERVER_PORT=3000
STREAMLIT_SERVER_HEADLESS=true

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Gradio
GRADIO_SERVER_PORT=7860
GRADIO_SERVER_NAME=0.0.0.0

# ============================================
# 安全与隐私
# ============================================
AI_TP_ENCRYPTION_ENABLED=true
AI_TP_ENCRYPTION_KEY=
AI_TP_ANONYMIZE_TELEMETRY=true

# ============================================
# 开发配置
# ============================================
DEBUG=false
RELOAD=false
TESTING=false
